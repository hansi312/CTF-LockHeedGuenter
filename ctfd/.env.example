# CTFd Server — Environment Variables
# Copy this to .env and fill in real values before running docker compose up.
# Never commit .env to git.
#
# Generate secrets:
#   SECRET_KEY:              openssl rand -hex 64
#   MARIADB_ROOT_PASSWORD:   openssl rand -hex 16
#   MARIADB_PASSWORD:        openssl rand -hex 16
#   CTF_KEY:                 openssl rand -hex 32

# CTFd application secret (session signing)
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_64

# MariaDB credentials
MARIADB_ROOT_PASSWORD=CHANGE_ME_root_password
MARIADB_PASSWORD=CHANGE_ME_ctfd_db_password

# -----------------------------------------------------------------
# CTF_KEY — MUST BE IDENTICAL ACROSS ALL 6 JUICE SHOP VMs
#
# This key is used to generate HMAC-SHA1 flag codes in Juice Shop.
# The same key must be used when running 02-export-challenges.sh.
# If any instance uses a different key, its flags will be rejected.
# -----------------------------------------------------------------
CTF_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
